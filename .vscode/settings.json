{
  "files.autoSave": "afterDelay",
  "editor.wordWrap": "on",
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.fontVariations": false,
  "claudeCode.allowDangerouslySkipPermissions": true,
  "claudeCode.environmentVariables": [],
  "claudeCode.initialPermissionMode": "bypassPermissions",

  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "使用英文编写 commit message。格式：`type(scope): 摘要`。type 包括 feat、fix、refactor、docs。scope 为模块名如 fastapi、ws、nonebot、shared_lib。摘要简洁描述改动原因，不超过 50 字。如有必要，在正文中补充细节。"
    }
  ],
  "python.terminal.activateEnvironment": false,
  "github.copilot.chat.reviewSelection.instructions": [],
  "files.associations": {
    "*.log": "ansi",
    "*.log.*": "ansi"
  },
  "python.analysis.typeCheckingMode": "off",
  // 禁用 VS Code 自带的 .env 解析器 —— 它不支持多行带引号的值
  // (如 TORTOISE_ORM),会把 `'{` 残片注入 os.environ 导致 pydantic-settings
  // 解析失败. pydantic-settings 在 Settings() 里用 python-dotenv 正确读 .env,
  // 无需 VS Code 再做一次.
  "python.envFile": "",
  "python.testing.pytestArgs": ["tests"],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true
}
