# ===========================
# App - 基本信息
# ===========================
VERSION="0.1.0"
APP_TITLE="FastSoyAdmin"
APP_DESCRIPTION="Description"
# 调试模式, 生产环境设为 false
DEBUG=false

# ===========================
# Security - 密钥与JWT
# ===========================
# 用于JWT签名的密钥, 生产环境务必更换! 可用 openssl rand -hex 32 生成
SECRET_KEY="your-secret-key-here"
# JWT算法
JWT_ALGORITHM="HS256"
# Access Token 过期时间(分钟), 默认12小时
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720
# Refresh Token 过期时间(分钟), 默认7天
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ===========================
# CORS - 跨域配置
# ===========================
# 允许的来源, 生产环境建议指定具体域名
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ===========================
# Database - Tortoise ORM
# ===========================
# JSON格式, 支持sqlite/postgres/mysql; migrations指向迁移模块路径
# sqlite示例:
TORTOISE_ORM='{
    "connections": {
        "conn_system": {
            "engine": "tortoise.backends.sqlite",
            "credentials": {"file_path": "app_system.sqlite3"}
        }
    },
    "apps": {
        "app_system": {"models": ["app.models.system", "app.radar.models"], "default_connection": "conn_system", "migrations": "migrations.app_system"}
    },
    "use_tz": false,
    "timezone": "Asia/Shanghai"
}'
# postgres示例:
# TORTOISE_ORM='{
#     "connections": {
#         "conn_system": "postgres://user:password@localhost:5432/dbname"
#     },
#     "apps": {
#         "app_system": {"models": ["app.models.system", "app.radar.models"], "default_connection": "conn_system", "migrations": "migrations.app_system"}
#     },
#     "use_tz": false,
#     "timezone": "Asia/Shanghai"
# }'

# ===========================
# Redis
# ===========================
# 格式: redis://:password@host:port/db
REDIS_URL="redis://localhost:6379/0"

# ===========================
# Datetime - 日期时间格式
# ===========================
DATETIME_FORMAT="%Y-%m-%d %H:%M:%S"

# ===========================
# Logs - 日志
# ===========================
# 普通日志(INFO/DEBUG/WARNING)保留时间, 支持: seconds/minutes/hours/days/weeks/months/years (如 "30 days", "1 months", "2 weeks")
LOG_INFO_RETENTION="30 days"

# ===========================
# Radar - 请求追踪
# ===========================
# 是否启用 Radar 请求追踪
RADAR_ENABLED=true
# Radar 数据库路径 (默认项目根目录下 radar.sqlite3)
# RADAR_DB_PATH="radar.sqlite3"
# 数据保留时间(小时)
RADAR_RETENTION_HOURS=24
# 记录的最大请求/响应体大小(字节)
RADAR_MAX_BODY_SIZE=65536
# 慢查询阈值(毫秒)
RADAR_SLOW_QUERY_THRESHOLD_MS=100.0
# 是否捕获响应体
RADAR_CAPTURE_RESPONSE_BODY=true
# 忽略追踪的路径(前缀匹配), JSON数组格式
# RADAR_EXCLUDE_PATHS='["/__radar", "/static", "/docs", "/openapi.json"]'
# 必须追踪的路径(前缀匹配), 优先级高于 EXCLUDE_PATHS
# RADAR_INCLUDE_PATHS='["/api/v1/auth/login"]'

# ===========================
# FastAPI Guard - 安全防护
# ===========================
# 是否启用 Guard
GUARD_ENABLED=true
# 速率限制: 每个窗口期内最大请求数
GUARD_RATE_LIMIT=100
# 速率限制窗口期(秒)
GUARD_RATE_LIMIT_WINDOW=60
# 自动封禁触发阈值(次)
GUARD_AUTO_BAN_THRESHOLD=10
# 自动封禁持续时间(秒), 默认6小时
GUARD_AUTO_BAN_DURATION=21600
