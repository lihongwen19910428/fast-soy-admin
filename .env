# ===========================
# App - 基本信息
# ===========================
VERSION="0.1.0"
APP_TITLE="FastSoyAdmin"
APP_DESCRIPTION="Description"
DEBUG=true

# ===========================
# Security - 密钥与JWT
# ===========================
# 用于JWT签名的密钥, 生产环境务必更换
SECRET_KEY="015a42020f023ac2c3eda3d45fe5ca3fef8921ce63589f6d4fcdef9814cd7fa7"
# JWT算法
JWT_ALGORITHM="HS256"
# Access Token 过期时间(分钟), 默认12小时
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720
# Refresh Token 过期时间(分钟), 默认7天
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ===========================
# CORS - 跨域配置
# ===========================
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ===========================
# Database - Tortoise ORM
# ===========================
# JSON格式, 支持sqlite/postgres/mysql; migrations指向迁移模块路径
TORTOISE_ORM='{
    "connections": {
        "conn_system": {
            "engine": "tortoise.backends.sqlite",
            "credentials": {"file_path": "app_system.sqlite3"}
        }
    },
    "apps": {
        "app_system": {"models": ["app.system.models", "app.system.radar.models", "app.business.hr.models"], "default_connection": "conn_system", "migrations": "migrations.app_system"}
    },
    "use_tz": false,
    "timezone": "Asia/Shanghai"
}'

# ===========================
# Redis
# ===========================
# 格式: redis://:password@host:port/db
REDIS_URL="redis://:sleep1223@192.168.0.104:6379/0"

# ===========================
# Datetime - 日期时间格式
# ===========================
DATETIME_FORMAT="%Y-%m-%d %H:%M:%S"

# ===========================
# Radar - 请求追踪
# ===========================
# 是否启用 Radar 请求追踪
RADAR_ENABLED=true
# Radar 数据库路径 (默认项目根目录下 radar.sqlite3)
# RADAR_DB_PATH="radar.sqlite3"
# 数据保留时间(小时)
RADAR_RETENTION_HOURS=24
# 记录的最大请求/响应体大小(字节)
RADAR_MAX_BODY_SIZE=65536
# 慢查询阈值(毫秒)
RADAR_SLOW_QUERY_THRESHOLD_MS=100.0
# 是否捕获响应体
RADAR_CAPTURE_RESPONSE_BODY=true
# 忽略追踪的路径(前缀匹配), JSON数组格式; 被排除的路径若调用了 radar_log 仍会落库
# RADAR_EXCLUDE_PATHS='["/__radar", "/static", "/docs", "/openapi.json", "/redoc", "/doc", "/api/v1/monitor/", "/api/v1/route/constant-routes", "/api/v1/route/user-routes", "/api/v1/auth/user-info"]'
# 必须追踪的路径(前缀匹配), 优先级高于 EXCLUDE_PATHS
# RADAR_INCLUDE_PATHS='["/api/v1/auth/login", "/api/v1/auth/code-login", "/api/v1/auth/register"]'

# ===========================
# FastAPI Guard - 安全防护
# ===========================
# 是否启用 Guard
GUARD_ENABLED=true
# 速率限制: 每个窗口期内最大请求数
GUARD_RATE_LIMIT=100
# 速率限制窗口期(秒)
GUARD_RATE_LIMIT_WINDOW=60
# 自动封禁触发阈值(次)
GUARD_AUTO_BAN_THRESHOLD=10
# 自动封禁持续时间(秒), 默认6小时
GUARD_AUTO_BAN_DURATION=21600
